* text=auto eol=lf

# Source files
*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary

# Export ignore (excluded from release archives)
/.github export-ignore
/.kiro export-ignore
/tests export-ignore
/docs export-ignore
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore
CONTRIBUTING.md export-ignore
phpunit.xml export-ignore
